{
  "name": "@vexcms/cli",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "vex": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "jiti": "^2.4.0"
  },
  "peerDependencies": {
    "@vexcms/core": "workspace:*"
  },
  "devDependencies": {
    "@vexcms/core": "workspace:*",
    "@vexcms/tsconfig": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
